# Environment variable overrides for Errandd.
# These variables override the corresponding fields in .claude/errandd/settings.json.
# Copy this file to .env and fill in the values you need.

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
CLAUDECLAW_MODEL=                        # Primary Claude model name (e.g. claude-opus-4-5)
CLAUDECLAW_API=                          # Anthropic API key or API URL override
CLAUDECLAW_FALLBACK_MODEL=               # Model to use when primary limit is reached
CLAUDECLAW_FALLBACK_API=                 # API key / URL for the fallback model
CLAUDECLAW_TIMEZONE=                     # Daemon timezone (e.g. America/New_York)
CLAUDECLAW_API_TOKEN=                    # Bearer token for /api/* web routes (auto-generated if unset)

# ---------------------------------------------------------------------------
# Web dashboard
# ---------------------------------------------------------------------------
CLAUDECLAW_WEB_ENABLED=true              # Enable the web dashboard (true/false)
CLAUDECLAW_WEB_HOST=0.0.0.0             # Host to bind the dashboard server
CLAUDECLAW_WEB_PORT=4632                 # Port to listen on

# ---------------------------------------------------------------------------
# Heartbeat
# ---------------------------------------------------------------------------
CLAUDECLAW_HEARTBEAT_ENABLED=            # Enable periodic heartbeat check-ins (true/false)
CLAUDECLAW_HEARTBEAT_INTERVAL=           # Heartbeat interval in minutes

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
CLAUDECLAW_SECURITY_LEVEL=               # Access level: readonly | normal | elevated | full

# ---------------------------------------------------------------------------
# Channels — tokens (aliases in parentheses also work)
# ---------------------------------------------------------------------------
CLAUDECLAW_TELEGRAM_TOKEN=               # Telegram bot token (alias: TELEGRAM_TOKEN)
CLAUDECLAW_DISCORD_TOKEN=                # Discord bot token (alias: DISCORD_TOKEN)
CLAUDECLAW_SLACK_BOT_TOKEN=              # Slack bot token, xoxb-… (alias: SLACK_BOT_TOKEN)
CLAUDECLAW_SLACK_APP_TOKEN=              # Slack app-level token, xapp-… (alias: SLACK_APP_TOKEN)

# ---------------------------------------------------------------------------
# Speech-to-text
# ---------------------------------------------------------------------------
CLAUDECLAW_STT_BASE_URL=                 # Base URL for the STT service
CLAUDECLAW_STT_MODEL=                    # STT model name

# ---------------------------------------------------------------------------
# Jobs repo
# ---------------------------------------------------------------------------
CLAUDECLAW_JOBSREPO_URL=                 # Git URL of a remote jobs repo (cloned on start)
CLAUDECLAW_JOBSREPO_BRANCH=main          # Branch to track
CLAUDECLAW_JOBSREPO_INTERVAL=300         # Pull interval in seconds
